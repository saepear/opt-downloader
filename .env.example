# MP3 Downloader — environment variables
# Copy this file to `.env.local` for development. All values shown are the
# defaults baked into src/lib/env.ts; override only when needed.

# Runtime mode (development | production | test)
NODE_ENV=development

# Path to yt-dlp binary. Install with `pipx install yt-dlp` or `brew install yt-dlp`.
YT_DLP_BIN=/usr/bin/yt-dlp

# Path to ffmpeg binary. Used by yt-dlp postprocessor to transcode to MP3.
FFMPEG_BIN=/usr/bin/ffmpeg

# Directory where downloaded files are staged before being streamed to the
# client. The cleanup job (Fase 6) will prune anything older than 24h.
DOWNLOAD_DIR=/tmp/mp3-downloader

# Max downloads per IP per minute. In-memory only — restarts wipe the bucket.
RATE_LIMIT_PER_MIN=10

# Cap of concurrent yt-dlp + ffmpeg processes. Keep low to avoid OOM.
MAX_CONCURRENT_DOWNLOADS=2

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Fase 3: auth + DB ---
# Path al archivo SQLite. Prisma lo crea automáticamente al correr migrate.
DATABASE_URL="file:./prisma/dev.db"

# Secreto para firmar JWTs de NextAuth. Generar uno nuevo con:
#   openssl rand -base64 32
# NUNCA commitear un valor real. En dev puede valer cualquier string >=32 chars.
AUTH_SECRET="S+umzl1B6hY5i7xSfFYLD4tMGQCfhnhSHNlXd9LUMB4="

# Secret for cron endpoints (/api/cron/cleanup). Generate with:
#   openssl rand -base64 32
# If not set, the cron route returns 401.
CRON_SECRET=""