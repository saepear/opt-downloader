// MP3 Downloader — Prisma schema (Fase 3)
// SQLite local para MVP. Migrar a Postgres en Fase 6 si el deploy lo requiere
// (Prisma lo soporta cambiando `provider` y `DATABASE_URL`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// NextAuth v4 (PrismaAdapter) requiere estos 3 modelos tal cual.
// Mantener los nombres canónicos — el adapter busca por nombre.
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Modelo de dominio: usuarios y descargas.
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  // Hash bcrypt del password. Para Fase 3 con Credentials provider.
  // En OAuth (Fase futura) podríamos dejarlo opcional.
  passwordHash String
  createdAt    DateTime   @default(now())

  accounts  Account[]
  sessions  Session[]
  downloads Download[]
}

model Download {
  id        String   @id @default(cuid())
  userId    String
  url       String
  // Slug de plataforma ("youtube", "soundcloud", etc.). Lo llena el server
  // desde detectPlatform(). Nullable para tracks importados antes de Fase 3.
  platform  String?
  // "mp3-320" | "best" — el formato que pidió el usuario.
  format    String
  // Título reportado por yt-dlp (ya sanitizado por basename).
  title     String
  // Artista / uploader cuando yt-dlp lo expone. Puede ser null (YouTube no
  // siempre tiene `artist`, solo `uploader`).
  artist    String?
  // "completed" | "failed".
  status    String
  // Código de error legible cuando status="failed" (DRM_PROTECTED, etc.).
  errorCode String?
  // Ruta en /tmp/mp3-downloader mientras el archivo existe. Se borra en Fase 6.
  filePath  String?
  // Tamaño en bytes del archivo entregado al cliente.
  bytes     Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Índice principal: historial de un usuario ordenado por fecha.
  @@index([userId, createdAt])
}